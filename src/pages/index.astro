---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Inicio" description="ServiciosJC — Soluciones tecnológicas profesionales: sistemas de inventario, desarrollo web, soporte técnico y más en Guatemala.">
  <Header />

  <!-- ═══════════════════════════════════════════
       HERO SECTION
  ═══════════════════════════════════════════ -->
  <section id="hero" style="position:relative; min-height:100vh; display:flex; align-items:center; overflow:hidden; background:#0f172a;">
    <!-- Background image via Unsplash -->
    <div style="position:absolute; inset:0; z-index:0;">
      <img
        src="https://images.unsplash.com/photo-1518770660439-4636190af475?w=1920&q=80"
        alt="Tecnología de fondo"
        style="width:100%; height:100%; object-fit:cover; opacity:0.18;"
        loading="eager"
      />
    </div>
    <!-- Gradient overlay -->
    <div class="hero-overlay" style="position:absolute; inset:0; z-index:1;"></div>
    <!-- Grid pattern -->
    <div class="grid-pattern" style="position:absolute; inset:0; z-index:2; opacity:0.4;"></div>

    <!-- Glowing orbs -->
    <div style="position:absolute; top:15%; left:10%; width:400px; height:400px; border-radius:50%; background:radial-gradient(circle, rgba(37,99,235,0.18) 0%, transparent 70%); z-index:2; pointer-events:none;"></div>
    <div style="position:absolute; bottom:20%; right:8%; width:350px; height:350px; border-radius:50%; background:radial-gradient(circle, rgba(6,182,212,0.14) 0%, transparent 70%); z-index:2; pointer-events:none;"></div>

    <div class="container-custom" style="position:relative; z-index:3; padding-top:5rem; padding-bottom:5rem;">
      <div style="max-width:750px;">
        <!-- Badge -->
        <div class="badge fade-in" style="margin-bottom:1.5rem; display:inline-flex;">
          <span style="width:8px;height:8px;border-radius:50%;background:#3b82f6;display:inline-block;animation:pulse-slow 2s infinite;"></span>
          Expertos en Tecnología & Soluciones IT
        </div>

        <!-- Headline -->
        <h1 class="fade-in" style="font-size:clamp(2.25rem,6vw,4rem); font-weight:900; line-height:1.1; letter-spacing:-0.02em; color:#fff; margin:0 0 1.5rem;">
          Tu socio de confianza en<br />
          <span class="gradient-text">Tecnología e Informática</span>
        </h1>

        <!-- Subheadline -->
        <p class="fade-in" style="font-size:clamp(1rem,2.5vw,1.25rem); color:rgba(255,255,255,0.7); max-width:580px; line-height:1.7; margin:0 0 2.5rem;">
          Sistemas de inventario, desarrollo web, soporte técnico y más.
          Soluciones profesionales adaptadas a tu empresa en Guatemala.
        </p>

        <!-- CTAs -->
        <div class="fade-in" style="display:flex; flex-wrap:wrap; gap:1rem;">
          <a href="/contact" class="btn-primary" id="hero-cta-quote">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/>
            </svg>
            Solicitar Cotización
          </a>
          <a href="https://wa.me/50212345678?text=Hola%2C%20me%20interesa%20un%20servicio." target="_blank" rel="noopener noreferrer" class="btn-whatsapp" id="hero-cta-wa">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
          <a href="/services" class="btn-secondary" id="hero-cta-services">
            Ver Servicios
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>

        <!-- Trust badges -->
        <div class="fade-in" style="display:flex; flex-wrap:wrap; gap:1.5rem; margin-top:3rem; padding-top:2rem; border-top:1px solid rgba(255,255,255,0.1);">
          {[
            { num: '500+', label: 'Clientes Satisfechos' },
            { num: '8+', label: 'Años de Experiencia' },
            { num: '1,000+', label: 'Proyectos Completados' },
            { num: '24/7', label: 'Soporte Disponible' },
          ].map(s => (
            <div style="text-align:left;">
              <div style="font-size:1.625rem; font-weight:800; color:#fff; line-height:1;">{s.num}</div>
              <div style="font-size:0.8rem; color:rgba(255,255,255,0.5); margin-top:0.25rem;">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

   
  </section>

  <!-- ═══════════════════════════════════════════
       SERVICES OVERVIEW
  ═══════════════════════════════════════════ -->
  <section id="servicios" style="padding:6rem 0; background:#111827;">
    <div class="container-custom">
      <!-- Section header -->
      <div style="text-align:center; margin-bottom:4rem;" class="fade-in">
        <span class="badge" style="margin-bottom:1rem;">Nuestros Servicios</span>
        <h2 style="font-size:clamp(1.75rem,4vw,2.5rem); font-weight:800; color:#fff; margin:0 0 1rem; letter-spacing:-0.02em;">
          Soluciones completas para tu <span class="gradient-text">negocio</span>
        </h2>
        <div class="section-divider"></div>
        <p style="color:rgba(255,255,255,0.6); max-width:520px; margin:1.25rem auto 0; line-height:1.7;">
          Ofrecemos una gama completa de servicios tecnológicos diseñados para impulsar tu empresa.
        </p>
      </div>

      <!-- Service cards -->
      <div class="stagger" style="display:grid; grid-template-columns:repeat(auto-fit, minmax(260px, 1fr)); gap:1.5rem;">
        {[
          {
            icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
            title: 'Sistemas de Inventario',
            desc: 'Controla tu stock en tiempo real con sistemas personalizados para tu negocio.',
            color: '#3b82f6',
            href: '/services',
          },
          {
            icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
            title: 'Desarrollo Web',
            desc: 'Páginas web modernas, rápidas y optimizadas para convertir visitantes en clientes.',
            color: '#06b6d4',
            href: '/services',
          },
          {
            icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
            title: 'Soporte Técnico',
            desc: 'Asistencia técnica rápida y confiable para mantener tus equipos funcionando.',
            color: '#8b5cf6',
            href: '/services',
          },
          {
            icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
            title: 'Servicio a Domicilio',
            desc: 'Te atendemos donde estés. Reparación y soporte técnico en tu hogar o empresa.',
            color: '#f59e0b',
            href: '/services',
          },
        ].map(card => (
          <div class="glass card-glow fade-in" style="border-radius:16px; padding:2rem; position:relative; overflow:hidden;">
            <div style={`width:56px; height:56px; border-radius:14px; background:${card.color}1a; border:1px solid ${card.color}33; display:flex; align-items:center; justify-content:center; color:${card.color}; margin-bottom:1.25rem;`}>
              <Fragment set:html={card.icon} />
            </div>
            <h3 style="font-size:1.125rem; font-weight:700; color:#fff; margin:0 0 0.75rem;">{card.title}</h3>
            <p style="color:rgba(255,255,255,0.6); font-size:0.9rem; line-height:1.6; margin:0 0 1.5rem;">{card.desc}</p>
            <a href={card.href} style={`color:${card.color}; font-size:0.875rem; font-weight:600; text-decoration:none; display:inline-flex; align-items:center; gap:0.35rem; transition:gap 0.2s ease;`} class="card-arrow-link">
              Conocer más
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
            <!-- decorative accent -->
            <div style={`position:absolute; top:-20px; right:-20px; width:80px; height:80px; border-radius:50%; background:${card.color}0d;`}></div>
          </div>
        ))}
      </div>

      <div style="text-align:center; margin-top:3rem;" class="fade-in">
        <a href="/services" class="btn-primary" id="home-all-services">Ver todos los servicios</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHY CHOOSE US
  ═══════════════════════════════════════════ -->
  <section style="padding:6rem 0; background:#0f172a; position:relative; overflow:hidden;">
    <div class="grid-pattern" style="position:absolute; inset:0; opacity:0.3;"></div>
    <div class="container-custom" style="position:relative; z-index:1;">
      <div style="display:grid; grid-template-columns:1fr; gap:4rem; align-items:center;">
       
        <!-- Right: content -->
        <div class="fade-in-right">
          <span class="badge" style="margin-bottom:1rem;">¿Por qué elegirnos?</span>
          <h2 style="font-size:clamp(1.75rem,4vw,2.5rem); font-weight:800; color:#fff; margin:0 0 1.25rem; letter-spacing:-0.02em;">
            Experiencia que <span class="gradient-text">genera resultados</span>
          </h2>
          <p style="color:rgba(255,255,255,0.65); line-height:1.75; margin:0 0 2rem; font-size:0.9375rem;">
            Con más de 8 años de experiencia, brindamos soluciones tecnológicas a medida que
            realmente funcionan. Nuestro compromiso es con tu éxito.
          </p>
          <div style="display:flex; flex-direction:column; gap:1rem;">
            {[
              { icon: '-', text: 'Respuesta rápida y atención personalizada' },
              { icon: '-', text: 'Seguridad y confidencialidad de tu información' },
              { icon: '-', text: 'Soluciones innovadoras adaptadas a tu presupuesto' },
              { icon: '-', text: 'Soporte continuo post-implementación' },
              { icon: '-', text: 'Servicio a domicilio en toda Guatemala' },
            ].map(item => (
              <div style="display:flex; align-items:center; gap:1rem; padding:0.875rem 1rem; border-radius:10px; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.07);">
                <span style="font-size:1.25rem; flex-shrink:0;">{item.icon}</span>
                <span style="color:rgba(255,255,255,0.8); font-size:0.9rem; font-weight:500;">{item.text}</span>
              </div>
            ))}
          </div>
          <div style="margin-top:2rem;">
            <a href="/about" class="btn-primary" id="home-about-link">Conocer más sobre nosotros</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CTA FINAL
  ═══════════════════════════════════════════ -->
  <section style="padding:6rem 0; background:#0f172a; position:relative; overflow:hidden;">
    <div style="position:absolute; inset:0; background:linear-gradient(135deg, rgba(37,99,235,0.1), rgba(6,182,212,0.06));"></div>
    <div style="position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:600px; height:300px; border-radius:50%; background:radial-gradient(ellipse, rgba(59,130,246,0.12) 0%, transparent 70%); pointer-events:none;"></div>
    <div class="container-custom" style="position:relative; z-index:1; text-align:center;">
      <div class="fade-in">
        <span class="badge" style="margin-bottom:1.25rem;">¿Listo para comenzar?</span>
        <h2 style="font-size:clamp(1.75rem,5vw,3rem); font-weight:900; color:#fff; margin:0 0 1.25rem; letter-spacing:-0.02em;">
          Lleva tu negocio al siguiente<br/><span class="gradient-text">nivel tecnológico</span>
        </h2>
        <p style="color:rgba(255,255,255,0.6); max-width:480px; margin:0 auto 2.5rem; font-size:1.0625rem; line-height:1.7;">
          Contáctanos hoy y recibe una consulta gratuita. Sin compromisos, sin costo.
        </p>
        <div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center;">
          <a href="/contact" class="btn-primary" id="cta-contact">
            Solicitar Cotización Gratis
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
          <a href="https://wa.me/30969323" target="_blank" rel="noopener noreferrer" class="btn-whatsapp" id="cta-whatsapp">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Escribir por WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  @media (min-width: 1024px) {
    #why-grid { grid-template-columns: 1fr 1fr !important; }
  }
  .card-arrow-link:hover { gap: 0.6rem !important; }
</style>
