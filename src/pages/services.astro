---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    id: 'inventario',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    title: 'Sistemas de Inventario',
    desc: 'Desarrollamos sistemas de control de inventario personalizados para tu tipo de negocio. Controla entradas, salidas, stock mínimo y genera reportes en tiempo real.',
    benefits: ['Control total de stock en tiempo real','Alertas de stock mínimo','Reportes y estadísticas','Acceso desde múltiples dispositivos','Respaldo automático de datos'],
    color: '#3b82f6',
    bg: 'rgba(59,130,246,0.12)',
  },
  {
    id: 'sistemas-negocios',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: 'Sistemas para Negocios Locales',
    desc: 'Soluciones informáticas integrales diseñadas especialmente para tiendas, restaurantes, farmacias, ferreterías y cualquier negocio local.',
    benefits: ['Punto de venta (POS) integrado','Gestión de clientes y proveedores','Control de caja y facturación','Reportes de ventas diarios/mensuales','Fácil de usar sin conocimientos técnicos'],
    color: '#10b981',
    bg: 'rgba(16,185,129,0.12)',
  },
  {
    id: 'sistemas-online',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>`,
    title: 'Sistemas en Línea',
    desc: 'Accede a tu sistema desde cualquier lugar del mundo con solo una conexión a internet. Perfecto para negocios con múltiples sucursales o trabajo remoto.',
    benefits: ['Acceso 24/7 desde cualquier dispositivo','Múltiples sucursales centralizadas','Alta disponibilidad y seguridad','Sin instalación en equipos locales','Actualizaciones automáticas'],
    color: '#06b6d4',
    bg: 'rgba(6,182,212,0.12)',
  },
  {
    id: 'desarrollo-web',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    title: 'Desarrollo de Páginas Web',
    desc: 'Creamos sitios web modernos, rápidos y optimizados para SEO que generan resultados reales para tu negocio. Desde landing pages hasta tiendas en línea.',
    benefits: ['Diseño moderno y profesional','Optimizado para Google (SEO)','Completamente responsive','Tienda en línea disponible','Dominio y hosting incluidos'],
    color: '#8b5cf6',
    bg: 'rgba(139,92,246,0.12)',
  },
  {
    id: 'soporte',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: 'Soporte Técnico',
    desc: 'Asistencia técnica profesional para resolver cualquier problema con tu equipo, software o red. Respuesta rápida y soluciones efectivas.',
    benefits: ['Diagnóstico gratuito','Solución el mismo día','Asistencia remota disponible','Garantía en reparaciones','Historial de servicio por cliente'],
    color: '#f59e0b',
    bg: 'rgba(245,158,11,0.12)',
  },
  {
    id: 'reparacion',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>`,
    title: 'Reparación de Computadoras',
    desc: 'Reparamos laptops y desktops de todas las marcas. Pantallas rotas, teclados dañados, problemas de arranque, virus y mucho más.',
    benefits: ['Todas las marcas y modelos','Pantallas, teclados y baterías','Eliminación de virus y malware','Recuperación de datos','Presupuesto sin compromiso'],
    color: '#ef4444',
    bg: 'rgba(239,68,68,0.12)',
  },
  {
    id: 'software',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="8 17 12 21 16 17"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.88 18.09A5 5 0 0018 9h-1.26A8 8 0 103 16.29"/></svg>`,
    title: 'Instalación de Software',
    desc: 'Instalación y configuración de sistemas operativos, antivirus, paquetes de oficina y software especializado para tu negocio.',
    benefits: ['Windows, macOS y Linux','Office y herramientas de productividad','Antivirus y seguridad','Software contable y empresarial','Configuración completa incluida'],
    color: '#06b6d4',
    bg: 'rgba(6,182,212,0.12)',
  },
 
  {
    id: 'mantenimiento',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93L17.66 6.34A8 8 0 104.93 19.07l1.41-1.41M22 12A10 10 0 0012 2"/></svg>`,
    title: 'Mantenimiento Preventivo',
    desc: 'Programa de mantenimiento periódico para tus equipos. Previene fallas, prolonga la vida útil y mantiene el rendimiento óptimo.',
    benefits: ['Limpieza interna y externa','Actualización de drivers y firmware','Optimización del sistema','Reporte detallado del estado','Planes mensuales y anuales'],
    color: '#10b981',
    bg: 'rgba(16,185,129,0.12)',
  },
  {
    id: 'domicilio',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M1 6v16l7-4 8 4 7-4V2l-7 4-8-4-7 4z"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>`,
    title: 'Servicio Técnico a Domicilio',
    desc: 'Nos desplazamos hasta tu hogar o empresa para brindarte el servicio. Sin que tengas que mover tus equipos ni perder tiempo en traslados.',
    benefits: ['Atención en hogares y empresas','Cobertura en toda Guatemala','Puntualidad garantizada','Sin costo adicional por desplazamiento'],
    color: '#f59e0b',
    bg: 'rgba(245,158,11,0.12)',
  },
];
---

<Layout title="Servicios" description="Descubre todos los servicios de ServiciosJC: sistemas de inventario, desarrollo web, soporte técnico, reparación de computadoras, redes y más.">
  <Header />

  <!-- Page Hero -->
  <section style="padding:5rem 0 3rem; background:#0f172a; position:relative; overflow:hidden;">
    <div class="grid-pattern" style="position:absolute; inset:0; opacity:0.3;"></div>
    <div style="position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg, transparent, #3b82f6, transparent);"></div>
    <div class="container-custom" style="position:relative; z-index:1; text-align:center;">
      <span class="badge fade-in" style="margin-bottom:1rem;">Nuestros Servicios</span>
      <h1 class="fade-in" style="font-size:clamp(2rem,5vw,3rem); font-weight:900; color:#fff; margin:0 0 1rem; letter-spacing:-0.02em;">
        Soluciones <span class="gradient-text">Tecnológicas</span> para ti
      </h1>
      <div class="section-divider"></div>
      <p class="fade-in" style="color:rgba(255,255,255,0.6); max-width:560px; margin:1.25rem auto 0; line-height:1.7;">
        Cada servicio está diseñado para resolver un problema real de tu negocio con la mejor calidad y precio.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section style="padding:5rem 0; background:#111827;">
    <div class="container-custom">
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(320px, 1fr)); gap:2rem;">
        {services.map((s, i) => (
          <article id={s.id} class="glass card-glow fade-in" style="border-radius:20px; padding:2rem; display:flex; flex-direction:column; gap:1.25rem;">
            <!-- Icon -->
            <div style={`width:64px; height:64px; border-radius:16px; background:${s.bg}; border:1px solid ${s.color}33; display:flex; align-items:center; justify-content:center; color:${s.color}; flex-shrink:0;`}>
              <Fragment set:html={s.icon} />
            </div>

            <!-- Title & Desc -->
            <div>
              <h2 style="font-size:1.125rem; font-weight:700; color:#fff; margin:0 0 0.625rem;">{s.title}</h2>
              <p style="color:rgba(255,255,255,0.65); font-size:0.9rem; line-height:1.7; margin:0;">{s.desc}</p>
            </div>

            <!-- Benefits -->
            <div>
              <h3 style="font-size:0.8125rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; color:rgba(255,255,255,0.4); margin:0 0 0.75rem;">Beneficios</h3>
              <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:0.5rem;">
                {s.benefits.map(b => (
                  <li style="display:flex; align-items:flex-start; gap:0.6rem; color:rgba(255,255,255,0.75); font-size:0.875rem;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={s.color} stroke-width="2.5" style="flex-shrink:0; margin-top:0.15rem;"><polyline points="20 6 9 17 4 12"/></svg>
                    {b}
                  </li>
                ))}
              </ul>
            </div>

            <!-- CTA -->
            <div style="margin-top:auto;">
              <a
                href={`/contact?servicio=${encodeURIComponent(s.title)}`}
                class="btn-primary"
                id={`service-cta-${s.id}`}
                style={`background:linear-gradient(135deg, ${s.color}, ${s.color}cc); border:none; justify-content:center; font-size:0.875rem;`}
              >
                Solicitar este servicio
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section style="padding:5rem 0; background:#0f172a; position:relative; overflow:hidden;">
    <div style="position:absolute; inset:0; background:linear-gradient(135deg,rgba(37,99,235,0.1),rgba(6,182,212,0.06));"></div>
    <div class="container-custom" style="position:relative; z-index:1; text-align:center;">
      <div class="fade-in">
        <h2 style="font-size:clamp(1.5rem,4vw,2.25rem); font-weight:800; color:#fff; margin:0 0 1rem; letter-spacing:-0.02em;">
          ¿No encuentras lo que necesitas?
        </h2>
        <p style="color:rgba(255,255,255,0.6); max-width:480px; margin:0 auto 2rem; line-height:1.7;">
          Cuéntanos tu problema y buscamos la solución tecnológica ideal para ti.
        </p>
        <div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center;">
          <a href="/contact" class="btn-primary" id="services-contact-cta">Contactar ahora</a>
          <a href="https://wa.me/30969323" target="_blank" rel="noopener noreferrer" class="btn-whatsapp" id="services-wa-cta">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp directo
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
