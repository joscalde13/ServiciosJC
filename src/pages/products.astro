---

<Layout title="Productos" description="Catálogo de productos tecnológicos en ServiciosJC: laptops, computadoras de escritorio, accesorios y componentes con los mejores precios en Guatemala.">
  <Header />

  <!-- Page Hero -->
  <section style="padding:5rem 0 3rem; background:#0f172a; position:relative; overflow:hidden;">
    <div class="grid-pattern" style="position:absolute; inset:0; opacity:0.3;"></div>
    <div style="position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg, transparent, #3b82f6, transparent);"></div>
    <div class="container-custom" style="position:relative; z-index:1; text-align:center;">
      <span class="badge fade-in" style="margin-bottom:1rem;">Catálogo de Productos</span>
      <h1 class="fade-in" style="font-size:clamp(2rem,5vw,3rem); font-weight:900; color:#fff; margin:0 0 1rem; letter-spacing:-0.02em;">
        Tecnología al <span class="gradient-text">mejor precio</span>
      </h1>
      <div class="section-divider"></div>
      <p class="fade-in" style="color:rgba(255,255,255,0.6); max-width:520px; margin:1.25rem auto 0; line-height:1.7;">
        Equipos nuevos con garantía. Laptops, computadoras, accesorios y componentes para todas las necesidades.
      </p>
    </div>
  </section>

  <!-- Category Filter -->
  <section style="padding:2rem 0; background:#111827; position:sticky; top:72px; z-index:40; border-bottom:1px solid rgba(255,255,255,0.06);">
    <div class="container-custom">
      <div id="category-filters" style="display:flex; gap:0.625rem; flex-wrap:wrap; justify-content:center;">
        {categories.map((cat, i) => (
          <button
            class="filter-btn"
            data-category={cat}
            id={`filter-${cat.toLowerCase()}`}
            style={`padding:0.5rem 1.25rem; border-radius:9999px; font-size:0.875rem; font-weight:600; cursor:pointer; border:1px solid; transition:all 0.25s ease; ${i === 0 ? 'background:#3b82f6; border-color:#3b82f6; color:#fff;' : 'background:transparent; border-color:rgba(255,255,255,0.15); color:rgba(255,255,255,0.65);'}`}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Products Grid -->
  <section style="padding:4rem 0 6rem; background:#111827;">
    <div class="container-custom">
      <div id="products-grid" style="display:grid; grid-template-columns:repeat(auto-fill, minmax(290px, 1fr)); gap:1.75rem;">
        {products.map(p => (
          <article
            class="product-card glass card-glow fade-in"
            data-category={p.category}
            id={p.id}
            style="border-radius:20px; overflow:hidden; display:flex; flex-direction:column;"
          >
            <!-- Image -->
            <div style="position:relative; overflow:hidden; height:200px;">
              <img
                src={p.image}
                alt={p.name}
                style="width:100%; height:100%; object-fit:cover; transition:transform 0.4s ease; display:block;"
                class="product-img"
                loading="lazy"
              />
              <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(15,23,42,0.7) 0%, transparent 60%);"></div>
              {p.badge && (
                <span style={`position:absolute; top:0.875rem; left:0.875rem; background:${p.badgeColor}; color:#fff; font-size:0.75rem; font-weight:700; padding:0.3rem 0.75rem; border-radius:9999px; letter-spacing:0.03em;`}>
                  {p.badge}
                </span>
              )}
            </div>

            <!-- Content -->
            <div style="padding:1.5rem; display:flex; flex-direction:column; gap:0.875rem; flex:1;">
              <div>
                <span style="font-size:0.75rem; font-weight:600; color:#3b82f6; text-transform:uppercase; letter-spacing:0.08em;">{p.category}</span>
                <h2 style="font-size:1.0625rem; font-weight:700; color:#fff; margin:0.3rem 0 0.5rem;">{p.name}</h2>
                <p style="color:rgba(255,255,255,0.6); font-size:0.875rem; line-height:1.6; margin:0;">{p.desc}</p>
              </div>

              <!-- Specs -->
              <div style="display:flex; flex-wrap:wrap; gap:0.4rem;">
                {p.specs.map(spec => (
                  <span style="font-size:0.75rem; background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.1); color:rgba(255,255,255,0.65); padding:0.2rem 0.6rem; border-radius:6px;">
                    {spec}
                  </span>
                ))}
              </div>

              <!-- Price + CTA -->
              <div style="display:flex; align-items:center; justify-content:space-between; margin-top:auto; padding-top:0.875rem; border-top:1px solid rgba(255,255,255,0.08);">
                <div>
                  <div style="font-size:0.75rem; color:rgba(255,255,255,0.4);">Precio</div>
                  <div style="font-size:1.5rem; font-weight:900; color:#3b82f6; line-height:1;">{p.price}</div>
                </div>
                <a
                  href={`/contact?producto=${encodeURIComponent(p.name)}`}
                  class="btn-primary"
                  id={`product-cta-${p.id}`}
                  style="font-size:0.8125rem; padding:0.6rem 1.1rem;"
                >
                  Consultar
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- No results -->
      <div id="no-results" style="display:none; text-align:center; padding:4rem 0; color:rgba(255,255,255,0.5);">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin:0 auto 1rem; opacity:0.4;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <p style="font-size:1.125rem; font-weight:600;">No hay productos en esta categoría</p>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section style="padding:5rem 0; background:#0f172a; position:relative; overflow:hidden;">
    <div style="position:absolute; inset:0; background:linear-gradient(135deg,rgba(37,99,235,0.08),rgba(6,182,212,0.05));"></div>
    <div class="container-custom" style="position:relative; z-index:1; text-align:center;">
      <div class="fade-in">
        <h2 style="font-size:clamp(1.5rem,4vw,2.25rem); font-weight:800; color:#fff; margin:0 0 1rem; letter-spacing:-0.02em;">
          ¿Buscas algo específico?
        </h2>
        <p style="color:rgba(255,255,255,0.6); max-width:460px; margin:0 auto 2rem; line-height:1.7;">
          Contáctanos y cotizamos cualquier equipo o accesorio que necesites.
          Trabajamos con los mejores distribuidores del mercado.
        </p>
        <div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center;">
          <a href="/contact" class="btn-primary" id="products-contact-cta">Solicitar Cotización</a>
          <a href="https://wa.me/30969323?text=Hola%2C%20busco%20un%20equipo%20específico." target="_blank" rel="noopener noreferrer" class="btn-whatsapp" id="products-wa-cta">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  // Category filter
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.product-card');
  const noResults = document.getElementById('no-results');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.category ?? 'Todos';

      // Update button styles
      filterBtns.forEach(b => {
        b.style.background = 'transparent';
        b.style.borderColor = 'rgba(255,255,255,0.15)';
        b.style.color = 'rgba(255,255,255,0.65)';
      });
      btn.style.background = '#3b82f6';
      btn.style.borderColor = '#3b82f6';
      btn.style.color = '#fff';

      // Filter cards
      let visible = 0;
      cards.forEach(card => {
        const match = cat === 'Todos' || card.dataset.category === cat;
        card.style.display = match ? 'flex' : 'none';
        if (match) visible++;
      });
      if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
    });
  });

  // Hover zoom on product images
  document.querySelectorAll<HTMLElement>('.product-img').forEach(img => {
    const parent = img.parentElement;
    parent?.addEventListener('mouseenter', () => { img.style.transform = 'scale(1.07)'; });
    parent?.addEventListener('mouseleave', () => { img.style.transform = 'scale(1)'; });
  });
</script>
