---
const navLinks = [
  { href: '/',          label: 'Inicio' },
  { href: '/about',     label: 'Nosotros' },
  { href: '/services',  label: 'Servicios' },
 
  { href: '/contact',   label: 'Contacto' },
];

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" style="background: rgba(15,23,42,0.85); backdrop-filter: blur(16px); border-bottom: 1px solid rgba(59,130,246,0.1);">
  <div class="container-custom">
    <div style="display:flex; align-items:center; justify-content:space-between; height:72px;">

      <!-- Logo & Brand -->
      <a href="/" style="display:flex; align-items:center; gap:0.75rem; text-decoration:none;" aria-label="ServiciosJC — Inicio">
        <!-- Logo Icon -->
        <img src="/img/logojc.jpeg" alt="ServiciosJC Logo" style="width:42px; height:42px; border-radius:10px; box-shadow:0 0 20px rgba(59,130,246,0.4); object-fit:contain;" />
        <div>
          <div style="font-size:1.125rem; font-weight:800; color:#fff; line-height:1.1; letter-spacing:-0.01em;">
            Servicios<span class="gradient-text">JC</span>
          </div>
          <div style="font-size:0.6875rem; color:rgba(255,255,255,0.5); font-weight:400; letter-spacing:0.04em; text-transform:uppercase;">
            Tecnología & Soluciones
          </div>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav id="desktop-nav" style="display:none;" aria-label="Navegación principal">
        <ul style="display:flex; align-items:center; gap:0.25rem; list-style:none; margin:0; padding:0;">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class={`nav-link ${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'active' : ''}`}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- CTA + Hamburger -->
      <div style="display:flex; align-items:center; gap:0.75rem;">
        <!-- Desktop CTA -->
        <a
          href="/contact"
          id="header-cta"
          class="btn-primary"
          style="display:none; font-size:0.875rem; padding:0.625rem 1.25rem;"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012.18 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 7.1a16 16 0 006 6l.62-.62a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/>
          </svg>
          Contáctanos
        </a>

        <!-- Hamburger -->
        <button
          id="hamburger-btn"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="mobile-menu"
          style="background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.12); border-radius:8px; padding:8px; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all 0.2s ease;"
        >
          <svg id="hamburger-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg id="close-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    style="display:none; background:rgba(15,23,42,0.97); backdrop-filter:blur(20px); border-top:1px solid rgba(59,130,246,0.15); padding:1rem 0 1.5rem;"
    aria-hidden="true"
  >
    <div class="container-custom">
      <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:0.25rem;">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={`nav-link ${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'active' : ''}`}
              style="display:block; padding:0.875rem 1rem; font-size:1rem;"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <div style="margin-top:1rem; padding-top:1rem; border-top:1px solid rgba(255,255,255,0.08); display:flex; flex-direction:column; gap:0.75rem;">
        <a href="/contact" class="btn-primary" style="justify-content:center;">
          Solicitar Cotización
        </a>
        <a href="https://wa.me/30969323" target="_blank" rel="noopener noreferrer" class="btn-whatsapp" style="justify-content:center;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="white">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer so content doesn't go under fixed header -->
<div style="height:72px;"></div>

<script>
  // Responsive nav visibility
  function applyResponsive() {
    const isDesktop = window.innerWidth >= 768;
    const desktopNav = document.getElementById('desktop-nav');
    const cta = document.getElementById('header-cta');
    const hamburger = document.getElementById('hamburger-btn');
    if (desktopNav) desktopNav.style.display = isDesktop ? 'block' : 'none';
    if (cta) cta.style.display = isDesktop ? 'inline-flex' : 'none';
    if (hamburger) hamburger.style.display = isDesktop ? 'none' : 'flex';
    if (!isDesktop) {
      const menu = document.getElementById('mobile-menu');
      if (menu) { menu.style.display = 'none'; menu.setAttribute('aria-hidden', 'true'); }
      const btn = document.getElementById('hamburger-btn');
      if (btn) btn.setAttribute('aria-expanded', 'false');
      const hi = document.getElementById('hamburger-icon');
      const ci = document.getElementById('close-icon');
      if (hi) hi.style.display = 'block';
      if (ci) ci.style.display = 'none';
    }
  }
  applyResponsive();
  window.addEventListener('resize', applyResponsive);

  // Hamburger toggle
  const btn = document.getElementById('hamburger-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.style.display === 'block';
    if (menu) menu.style.display = isOpen ? 'none' : 'block';
    if (menu) menu.setAttribute('aria-hidden', String(isOpen));
    if (btn) btn.setAttribute('aria-expanded', String(!isOpen));
    if (hamburgerIcon) hamburgerIcon.style.display = isOpen ? 'block' : 'none';
    if (closeIcon) closeIcon.style.display = isOpen ? 'none' : 'block';
  });

  // Header scroll effect
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.style.setProperty('background', 'rgba(15,23,42,0.97)');
      header?.style.setProperty('box-shadow', '0 4px 30px rgba(0,0,0,0.4)');
    } else {
      header?.style.setProperty('background', 'rgba(15,23,42,0.85)');
      header?.style.setProperty('box-shadow', 'none');
    }
  });
</script>
